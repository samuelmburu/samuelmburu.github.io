---
import { getResumeData } from "../data/resume";

const { profile, strengths, technologies, timeline } = await getResumeData();
const technologyLine = technologies.join(" • ");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{profile.name} Resume</title>
    <style>
      :root {
        --page-width: 8.5in;
        --page-height: 11in;
        --page-margin: 0.5in;
        --text: #111111;
        --muted: #4f4f4f;
        --line: #d6d6d6;
        --accent: #2563eb;
      }

      @page {
        size: 8.5in 11in;
        margin: 0;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        color: var(--text);
        background: #ffffff;
        font-family: "Inter", "Avenir Next", "Segoe UI", sans-serif;
      }

      body {
        width: var(--page-width);
        min-height: var(--page-height);
      }

      main {
        width: 100%;
        padding: var(--page-margin);
      }

      .header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 0.3in;
        align-items: start;
        /* padding-bottom: 0.18in; */
        /* border-bottom: 1px solid var(--line); */
      }

      .name {
        margin: 0;
        font-size: 28px;
        line-height: 1;
        letter-spacing: -0.04em;
      }

      .headline {
        margin: 0.08in 0 0;
        font-size: 12.5px;
        color: var(--muted);
      }

      .contact {
        text-align: right;
        font-size: 10.5px;
        line-height: 1.5;
      }

      .contact a {
        color: inherit;
        text-decoration: none;
      }

      .summary {
        margin-top: 0.16in;
        font-size: 11px;
        line-height: 1.42;
      }

      .grid {
        display: grid;
        grid-template-columns: 2.1fr 1fr;
        gap: 0.28in;
        margin-top: 0.2in;
        align-items: start;
      }

      .section + .section {
        margin-top: 0.18in;
      }

      .section-title {
        margin: 0 0 0.08in;
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .strengths {
        margin: 0;
        padding-left: 0.16in;
        font-size: 10.5px;
        line-height: 1.45;
      }

      .strengths li + li {
        margin-top: 0.04in;
      }

      .role + .role {
        /* margin-top: 0.15in; */
        padding-top: 0.15in;
        /* border-top: 1px solid #ececec; */
        break-inside: avoid;
      }

      .role-header {
        display: flex;
        justify-content: space-between;
        gap: 0.12in;
        align-items: baseline;
      }

      .role-title {
        margin: 0;
        font-size: 11px;
        font-weight: 700;
      }

      .role-company {
        color: var(--muted);
        font-weight: 600;
      }

      .role-period {
        flex-shrink: 0;
        color: var(--muted);
        font-size: 9.5px;
      }

      .role-summary {
        margin: 0.04in 0 0;
        font-size: 10px;
        line-height: 1.4;
      }

      .role-scope {
        margin: 0.02in 0 0;
        font-size: 9.5px;
        color: var(--muted);
      }

      .role-highlights {
        margin: 0.06in 0 0;
        padding-left: 0.16in;
        font-size: 9.6px;
        line-height: 1.32;
      }

      .role-highlights li + li {
        margin-top: 0.03in;
      }

      .role-impact {
        margin: 0.06in 0 0;
        font-size: 9.8px;
        line-height: 1.35;
      }

      .skills-copy {
        font-size: 10.2px;
        line-height: 1.45;
        color: var(--muted);
      }

      .footer-note {
        margin-top: 0.16in;
        font-size: 9.5px;
        color: var(--muted);
      }
    </style>
  </head>
  <body>
    <main>
      <header class="header">
        <div>
          <h1 class="name">{profile.name}</h1>
          <p class="headline">
            {profile.headline} { profile.location && `• ${profile.location}` }
          </p>
        </div>
        <div class="contact">
          {profile.contact.email !== "email" && (
            <div>{profile.contact.email}</div>
          )}
          {profile.contact.linkedin && (
            <div>
              <a href={profile.contact.linkedin}
                >{profile.contact.linkedin.replace("https://", "")}</a>
            </div>
          )}
          {profile.contact.github && (
            <div>
              <a href={profile.contact.github}
                >{profile.contact.github.replace("https://", "")}</a>
            </div>
          )}
        </div>
      </header>

      <p class="summary">{profile.summary}</p>

      <div class="section">
        <h2 class="section-title">Core Strengths</h2>
        <ul class="strengths">
          {strengths.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="section section-grid">


        <div class="section-grid">
          <h2 class="section-title">Experience</h2>
          {
            timeline.map((entry) => (
              <article class="role">
                <div class="role-header">
                  <h3 class="role-title">
                    {entry.role}{" "}
                    <span class="role-company">• {entry.company}</span>
                  </h3>
                  <span class="role-period">{entry.period}</span>
                </div>
                {/* {entry.scope && <p class="role-scope">{entry.scope}</p>} */}
                <p class="role-summary">{entry.summary}</p>
                <ul class="role-highlights">
                  {entry.highlights.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
                <p class="role-impact">
                  <strong>Impact:</strong> {entry.impact}
                </p>
              </article>
            ))
          }
        </div>

        <div class="section-grid">
          <h2 class="section-title">Technologies</h2>
          <div class="skills-copy">{technologyLine}</div>
        </div>

        <div class="section-grid">
          <h2 class="section-title">Education</h2>
          <div class="skills-copy">
            B.S. Computer Science & Engineering — The Ohio State University
          </div>
        </div>

        <!-- <div class="section">
          <h2 class="section-title">Note</h2>
          <div class="skills-copy">
            Full employment history and expanded role detail available on
            request or in the web version of this resume.
          </div>
        </div>

        <p class="footer-note">
          Generated from the same YAML source that powers the site.
        </p> -->
        <!-- </section> -->
      </div>
    </main>
  </body>
</html>
