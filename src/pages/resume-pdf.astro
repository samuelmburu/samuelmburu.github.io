---
import { getResumeData } from "../data/resume";

const { profile, strengths, technologies, timeline } = await getResumeData();
const technologyLine = technologies.join(" • ");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{profile.name} Resume</title>
    <style>
      :root {
        --page-width: 8.5in;
        --page-height: 11in;
        --page-margin: 0.5in;
        --text: #111111;
        --muted: #4f4f4f;
        --line: #d6d6d6;
        --accent: #2563eb;
      }

      @page {
        size: 8.5in 11in;
        margin: 0;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        color: var(--text);
        background: #ffffff;
        font-family: "Inter", "Avenir Next", "Segoe UI", sans-serif;
      }

      body {
        min-height: 100vh;
      }

      main {
        width: var(--page-width);
        min-height: var(--page-height);
        padding: var(--page-margin);
        display: grid; gap: 0.05in;
        background: #ffffff;
      }

      @media screen {
        html,
        body {
          background:
            radial-gradient(circle at top left, rgba(37, 99, 235, 0.06), transparent 28%),
            linear-gradient(180deg, #f4f1ea 0%, #ebe6dc 100%);
        }

        body {
          display: flex;
          justify-content: center;
          padding: 2rem 1rem 3rem;
        }

        main {
          box-shadow:
            0 24px 60px rgba(22, 22, 22, 0.14),
            0 8px 22px rgba(22, 22, 22, 0.08);
          border: 1px solid rgba(17, 17, 17, 0.08);
        }
      }

      @media print {
        html,
        body {
          background: #ffffff;
        }

        body {
          display: block;
          padding: 0;
        }

        main {
          box-shadow: none;
          border: 0;
        }
      }

      .header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 0.3in;
        align-items: start;
        /* padding-bottom: 0.18in; */
        /* border-bottom: 1px solid var(--line); */
      }

      .name {
        margin: 0;
        font-size: 28px;
        line-height: 1;
        letter-spacing: -0.04em;
      }

      .headline {
        margin: 0.08in 0 0;
        font-size: 12.5px;
        color: var(--muted);
      }

      .contact {
        text-align: right;
        font-size: 10.5px;
        line-height: 1.5;
      }

      .contact a {
        color: inherit;
        text-decoration: none;
      }

      .summary {
        margin-top: 0.12in;
        font-size: 10.6px;
        line-height: 1.35;
      }

      .resume-layout {
        display: grid;
        grid-template-columns: 2.25fr 0.95fr;
        gap: 0.22in;
        margin-top: 0.14in;
        align-items: start;
      }

      .section + .section {
        margin-top: 0.12in;
      }

      .section-title {
        margin: 0 0 0.06in;
        font-size: 9.5px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .strengths {
        margin: 0;
        padding-left: 0.16in;
        column-count: 2;
        column-gap: 0.18in;
        font-size: 9.8px;
        line-height: 1.28;
      }

      .strengths li {
        break-inside: avoid;
        margin-bottom: 0.04in;
      }

      .role + .role {
        padding-top: 0.11in;
        break-inside: avoid;
      }

      .role-header {
        display: flex;
        justify-content: space-between;
        gap: 0.12in;
        align-items: baseline;
      }

      .role-title {
        margin: 0;
        font-size: 10.4px;
        font-weight: 700;
      }

      .role-company {
        color: var(--muted);
        font-weight: 600;
      }

      .role-period {
        flex-shrink: 0;
        color: var(--muted);
        font-size: 9px;
      }

      .role-summary {
        margin: 0.03in 0 0;
        font-size: 9.5px;
        line-height: 1.28;
      }

      .role-scope {
        margin: 0.02in 0 0;
        font-size: 9.5px;
        color: var(--muted);
      }

      .role-highlights {
        margin: 0.04in 0 0;
        padding-left: 0.16in;
        font-size: 9.1px;
        line-height: 1.22;
      }

      .role-highlights li + li {
        margin-top: 0.015in;
      }

      .role-impact {
        margin: 0.04in 0 0;
        font-size: 9.1px;
        line-height: 1.22;
      }

      .skills-copy {
        font-size: 9.3px;
        line-height: 1.3;
        color: var(--muted);
      }

      .footer-note {
        margin-top: 0.16in;
        font-size: 9.5px;
        color: var(--muted);
      }
    </style>
  </head>
  <body>
    <main>
      <header class="header">
        <div>
          <h1 class="name">{profile.name}</h1>
          <p class="headline">
            {profile.headline} { profile.location && `• ${profile.location}` }
          </p>
        </div>
        <div class="contact">
          {profile.contact.email !== "email" && (
            <div>{profile.contact.email}</div>
          )}
          {profile.contact.linkedin && (
            <div>
              <a href={profile.contact.linkedin}
                >{profile.contact.linkedin.replace("https://", "")}</a>
            </div>
          )}
          {profile.contact.github && (
            <div>
              <a href={profile.contact.github}
                >{profile.contact.github.replace("https://", "")}</a>
            </div>
          )}
        </div>
      </header>

      <p class="summary">{profile.summary}</p>

      <!-- <div class="resume-layout"> -->
        <section>
          <h2 class="section-title">Experience</h2>
          {
            timeline.map((entry) => (
              <article class="role">
                <div class="role-header">
                  <h3 class="role-title">
                    {entry.role}{" "}
                    <span class="role-company">• {entry.company}</span>
                  </h3>
                  <span class="role-period">{entry.period}</span>
                </div>
                {/* {entry.scope && <p class="role-scope">{entry.scope}</p>} */}
                <p class="role-summary">{entry.summary}</p>
                <ul class="role-highlights">
                  {entry.highlights.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
                <p class="role-impact">
                  <strong>Impact:</strong> {entry.impact}
                </p>
              </article>
            ))
          }
          </section>

          <section class="section" style="margin-top: 0.14in;">
            <h2 class="section-title">Core Strengths</h2>
            <ul class="strengths">
              {strengths.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section class="section">
          <div class="section">
            <h2 class="section-title">Technologies</h2>
            <div class="skills-copy">{technologyLine}</div>
          </div>
          </section>

          <section class="section">
          <div class="section">
            <h2 class="section-title">Education</h2>
            <div class="skills-copy">
              B.S. Computer Science & Engineering — The Ohio State University
            </div>
            </div>
          </section>

      <!-- </div> -->
    </main>
  </body>
</html>
