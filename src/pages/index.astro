---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  profile,
  socialLinks,
  strengths,
  technologies,
  timeline,
} from "../data/resume";
import { siteContent } from "../data/site";

const recentTimeline = timeline.slice(0, 2);
const additionalTimeline = timeline.slice(2);
---

<BaseLayout title={`${profile.name} | Portfolio`} description={profile.summary}>
  <section class="hero" id="home">
    <div>
      <p class="hero-kicker">Hi, I&apos;m</p>
      <h1>Samuel Kimama,</h1>
      <h2 class="hero-subtitle">I build resilient frontend systems for complex products.</h2>
      <p class="lead" style="margin-top: 1.5rem;">{profile.summary}</p>
      <!-- <ul class="hero-facts" aria-label="Profile highlights">
        {stats.map((item) => (
          <li>
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </li>
        ))}
      </ul> -->
      <div class="social-links" aria-label="Social links">
        {
          socialLinks.map((item) => (
            <a
              class="social-link"
              href={item.href}
              target="_blank"
              rel="noreferrer"
              aria-label={item.label}
              title={item.label}
            >
              {
                item.label === "Email" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M3 6.75h18v10.5H3z" fill="none" stroke="currentColor" stroke-width="1.7"/>
                    <path d="m4.5 8.25 7.5 6 7.5-6" fill="none" stroke="currentColor" stroke-width="1.7"/>
                  </svg>
                )
              }
              {
                item.label === "LinkedIn" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M6.75 8.25a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3ZM5.5 10h2.5v8.5H5.5zM10.5 10H13v1.4h.04c.35-.66 1.2-1.4 2.46-1.4 2.63 0 3.12 1.73 3.12 3.98V18.5h-2.5v-4c0-.95-.02-2.18-1.33-2.18-1.34 0-1.54 1.04-1.54 2.1v4.08h-2.5z" fill="currentColor"/>
                  </svg>
                )
              }
              {
                item.label === "GitHub" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 3.75a8.25 8.25 0 0 0-2.61 16.08c.41.08.56-.18.56-.4v-1.4c-2.28.5-2.76-.97-2.76-.97-.37-.94-.9-1.19-.9-1.19-.74-.5.06-.5.06-.5.81.06 1.24.83 1.24.83.73 1.24 1.9.88 2.36.67.07-.53.28-.88.51-1.08-1.82-.21-3.74-.91-3.74-4.06 0-.9.32-1.63.84-2.2-.08-.2-.36-1.03.08-2.14 0 0 .68-.22 2.23.84a7.8 7.8 0 0 1 4.06 0c1.55-1.06 2.23-.84 2.23-.84.44 1.11.16 1.94.08 2.14.52.57.84 1.3.84 2.2 0 3.16-1.92 3.85-3.75 4.06.29.25.55.75.55 1.51v2.24c0 .22.15.48.57.4A8.25 8.25 0 0 0 12 3.75Z" fill="currentColor"/>
                  </svg>
                )
              }
              <span>{item.label}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

{
  false && (
    <section class="section" id="about">
    <div class="section-heading">
      <div>
        <span class="eyebrow">About</span>
        <h2>Architecture, leverage, and complex product work.</h2>
      </div>
      <p>
        Senior frontend engineer operating with Staff / Principal scope
        across platform, product, and organizational boundaries.
      </p>
    </div>
    <div class="resume-grid" style="margin-top: 1rem;">
      <article class="panel">
        {siteContent.about.map((paragraph) => (
          <p style="margin-top: 1rem;">{paragraph}</p>
        ))}
      </article>
      <article class="panel">
        <h3>Core strengths</h3>
        <ul class="list">
          {strengths.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>
)}

  {
    false && (
      <section class="section">
        <div class="section-heading">
          <div>
            <span class="eyebrow">Expertise</span>
            <h2>What I focus on.</h2>
          </div>
        </div>
        <div class="section-grid">
          {siteContent.expertise.map((item) => (
            <article class="panel">
              <h3>{item.title}</h3>
              <p style="margin-top: 0.75rem;">{item.description}</p>
            </article>
          ))}
        </div>
      </section>
    )
  }

  {
    siteContent.projects.length > 2 && (
      <section class="section" id="projects">
        <div class="section-heading">
          <div>
            <span class="eyebrow">Projects</span>
            <h2>Personal projects and active explorations.</h2>
          </div>
          <p>
            A few independent projects that reflect what you like building when
            you are not writing a resume.
          </p>
        </div>
        <div class="project-grid">
          {siteContent.projects.map((project) => (
            <article class="project-card">
              <div class="project-meta">
                <span>{project.category}</span>
                <span>{project.year}</span>
              </div>
              <h3>{project.name}</h3>
              <p style="margin-top: 0.75rem;">{project.description}</p>
              <div class="actions">
                <a class="text-link" href={project.href}>
                  View section
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>
    )
  }

  <section class="section" id="resume">
    <div class="section-heading">
      <div>
        <!-- <span class="eyebrow">Resume</span> -->
        <h2>Experience and supporting detail.</h2>
      </div>
      <!-- <p>{siteContent.availability}</p> -->
    </div>
    <div class="actions" style="margin-top: 0; margin-bottom: 1rem;">
      <a class="button button--secondary" href="/resume-samuel.txt" download>
        Download resume
      </a>
    </div>
    <div class="timeline" style="grid-template-columns: 1fr; gap: 1rem;">
      {
        recentTimeline.map((entry) => (
          <article class="timeline-item">
            <div class="timeline-meta">
              <span>{entry.period}</span>
              <span>{entry.scope}</span>
            </div>
            <h3>{entry.role}</h3>
            <p style="margin-top: 0.35rem;">{entry.company}</p>
            <p style="margin-top: 0.85rem;">{entry.summary}</p>
            <ul class="list">
              {entry.highlights.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <p style="margin-top: 1rem;">
              <strong>Impact:</strong> {entry.impact}
            </p>
          </article>
        ))
      }
    </div>
    {
      additionalTimeline.length > 0 && (
        <details class="resume-details">
          <summary>See more experience</summary>
          <div class="timeline" style="grid-template-columns: 1fr; gap: 1rem; margin-top: 1rem;">
            {
              additionalTimeline.map((entry) => (
                <article class="timeline-item">
                  <div class="timeline-meta">
                    <span>{entry.period}</span>
                    <span>{entry.scope}</span>
                  </div>
                  <h3>{entry.role}</h3>
                  <p style="margin-top: 0.35rem;">{entry.company}</p>
                  <p style="margin-top: 0.85rem;">{entry.summary}</p>
                  <ul class="list">
                    {entry.highlights.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                  <p style="margin-top: 1rem;">
                    <strong>Impact:</strong> {entry.impact}
                  </p>
                </article>
              ))
            }
          </div>
        </details>
      )
    }
    <div class="section-grid" style="margin-top: 1rem;">
      <article class="resume-block">
        <h3>Technologies</h3>
        <ul class="list">
          {technologies.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
