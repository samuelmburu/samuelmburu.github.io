---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getResumeData } from "../data/resume";
import { siteContent } from "../data/site";

const { profile, strengths, technologies, timeline } = await getResumeData();
const recentTimeline = timeline.slice(0, 2);
const additionalTimeline = timeline.slice(2);
const resumeDownloadHref = import.meta.env.DEV ? "/resume-pdf" : "/Samuel-Kimama-Resume.pdf";
---

<BaseLayout title={`${profile.name} | Portfolio`} description={profile.summary}>
  <section class="hero" id="home">
    <div>
      <p class="hero-kicker">Hi, I&apos;m</p>
      <h1>Samuel Kimama,</h1>
      <h2 class="hero-subtitle">I build resilient frontend systems for complex products.</h2>
      <p class="lead" style="margin-top: 1.5rem;">{profile.summary}</p>
      <!-- <ul class="hero-facts" aria-label="Profile highlights">
        {stats.map((item) => (
          <li>
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </li>
        ))}
      </ul> -->
    </div>
  </section>

{
  false && (
    <section class="section" id="about">
    <div class="section-heading">
      <div>
        <span class="eyebrow">About</span>
        <h2>Architecture, leverage, and complex product work.</h2>
      </div>
      <p>
        Senior frontend engineer operating with Staff / Principal scope
        across platform, product, and organizational boundaries.
      </p>
    </div>
    <div class="resume-grid" style="margin-top: 1rem;">
      <article class="panel">
        {siteContent.about.map((paragraph) => (
          <p style="margin-top: 1rem;">{paragraph}</p>
        ))}
      </article>
      <article class="panel">
        <h3>Core strengths</h3>
        <ul class="list">
          {strengths.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>
)}

  {
    false && (
      <section class="section">
        <div class="section-heading">
          <div>
            <span class="eyebrow">Expertise</span>
            <h2>What I focus on.</h2>
          </div>
        </div>
        <div class="section-grid">
          {siteContent.expertise.map((item) => (
            <article class="panel">
              <h3>{item.title}</h3>
              <p style="margin-top: 0.75rem;">{item.description}</p>
            </article>
          ))}
        </div>
      </section>
    )
  }

  <section class="section" id="resume">
    <div class="section-heading">
      <div>
        <span class="eyebrow" style="margin-bottom: 0;">Resume</span>
        <h2>Experience and supporting detail.</h2>
      </div>
      <!-- <p>{siteContent.availability}</p> -->
    </div>
    <div class="actions" style="margin-top: 0; margin-bottom: 1rem;">
      <a
        class="button button--secondary resume-action"
        href={resumeDownloadHref}
        download={import.meta.env.DEV ? undefined : true}
        target={import.meta.env.DEV ? "_blank" : undefined}
        rel={import.meta.env.DEV ? "noreferrer" : undefined}
      >
        <Icon name="lucide:download" size="1rem" aria-hidden="true" />
        Download resume
      </a>
    </div>
    <div class="timeline" style="grid-template-columns: 1fr; gap: 1rem;">
      {
        recentTimeline.map((entry) => (
          <article class="timeline-item">
            <div class="timeline-meta">
              <span>{entry.period}</span>
              {/* <span>{entry.scope}</span> */}
            </div>
            <h3>{entry.role}</h3>
            <p style="margin-top: 0.35rem;">{entry.company}</p>
            <p style="margin-top: 0.85rem;">{entry.summary}</p>
            <ul class="list">
              {entry.highlights.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <p style="margin-top: 1rem;">
              <strong>Impact:</strong> {entry.impact}
            </p>
          </article>
        ))
      }
    </div>
    {
      additionalTimeline.length > 0 && (
        <details class="resume-details">
          <summary class="resume-action">See more experience</summary>
          <div class="timeline" style="grid-template-columns: 1fr; gap: 1rem; margin-top: 1rem;">
            {
              additionalTimeline.map((entry) => (
                <article class="timeline-item">
                  <div class="timeline-meta">
                    <span>{entry.period}</span>
                    {/* <span>{entry.scope}</span> */}
                  </div>
                  <h3>{entry.role}</h3>
                  <p style="margin-top: 0.35rem;">{entry.company}</p>
                  <p style="margin-top: 0.85rem;">{entry.summary}</p>
                  <ul class="list">
                    {entry.highlights.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                  <p style="margin-top: 1rem;">
                    <strong>Impact:</strong> {entry.impact}
                  </p>
                </article>
              ))
            }
          </div>
        </details>
      )
    }
    <div class="section">
      <article class="resume-block">
        <h3>Technologies</h3>
        <ul class="list technologies-list">
          {technologies.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  {
    (
      <section class="section" id="projects">
        <div class="section-heading">
          <div>
            <span class="eyebrow" style="margin-bottom: 0;">Projects</span>
            <h2>Personal projects and active explorations.</h2>
          </div>
        </div>
        <div class="project-grid">
          {siteContent.projects.map((project) => (
            <article class="project-card">
              <div class="project-meta">
                <span>{project.category}</span>
                <span>{project.year}</span>
              </div>
              <h3>{project.name}</h3>
              <p style="margin-top: 0.75rem;">{project.description}</p>
              {/* <div class="actions">
                <a class="text-link" href={project.href}>
                  View section
                </a>
              </div> */}
            </article>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
