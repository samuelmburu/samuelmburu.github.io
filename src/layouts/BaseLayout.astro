---
import SiteHead from "../components/SiteHead.astro";
import { Icon } from "astro-icon/components";
import "../styles/global.css";
import { getResumeData } from "../data/resume";
import { siteContent } from "../data/site";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const { profile, socialLinks } = await getResumeData();

const navItems = [
  { href: "#home", label: "Home" },
  { href: "#resume", label: "Resume" },
  siteContent.projects.length > 0 && { href: "#projects", label: "Projects" },
].filter(Boolean) as { href: string; label: string }[];
---

<!doctype html>
<html lang="en">
  <head>
    <SiteHead title={title} description={description} />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const theme = stored || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="shell site-header__inner">
        <a class="brand" href="/">
          <span class="brand__mark" aria-hidden="true">
            <span class="brand__mark-chevron">&gt;</span><span title={profile.name}>sk</span>
          </span>
        </a>
        <div class="header-actions">
          <nav class="nav" aria-label="Primary">
            {
              navItems.map((item) => (
                <a href={item.href}>
                  {item.label}
                </a>
              ))
            }
          </nav>
          <div class="header-socials" aria-label="Social links">
            <button class="theme-toggle" type="button" aria-label="Toggle color theme" title="Toggle color theme">
              <span class="theme-toggle__sun" aria-hidden="true">
                <Icon name="lucide:sun" size="1.2rem" />
              </span>
              <span class="theme-toggle__moon" aria-hidden="true">
                <Icon name="lucide:moon" size="1.2rem" />
              </span>
            </button>
            {
              socialLinks.map((item) => (
                <a
                  class="header-social"
                  href={item.href}
                  target="_blank"
                  rel="noreferrer"
                  aria-label={item.label}
                  title={item.label}
                >
                  {item.label === "LinkedIn" && <Icon name="mdi:linkedin" size="1.35rem" aria-hidden="true" />}
                  {item.label === "GitHub" && <Icon name="mdi:github" size="1.35rem" aria-hidden="true" />}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </header>
    <main>
      <div class="shell">
        <slot />
      </div>
    </main>
    <footer class="shell site-footer">
       <p class="muted text-sm text-right">Built with Astro &copy; {new Date().getFullYear()}</p>
    </footer>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const button = document.querySelector(".theme-toggle");
        if (!button) return;

        button.addEventListener("click", () => {
          const next = root.dataset.theme === "dark" ? "light" : "dark";
          root.dataset.theme = next;
          localStorage.setItem("theme", next);
        });
      })();
    </script>
  </body>
</html>
